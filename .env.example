# --- Database (Neon) -------------------------------------------------------
# Get this from your Neon project dashboard -> Connection string (pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Single-user seed ------------------------------------------------------
# The id of the seeded user that owns all rows until multi-user is added.
DEFAULT_USER_EMAIL="you@example.com"

# --- Auth (password gate) --------------------------------------------------
# Single password that unlocks the whole app. If unset, the gate is DISABLED
# (the app is open) — you MUST set this before deploying anywhere public.
APP_PASSWORD=""
# Secret for signing the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=""

# --- Intelligence / cost controls (Phase 1: all OFF) -----------------------
# These are read by future scheduled/AI features. Leave AI disabled for now.
AI_AUTOMATION_ENABLED="false"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# --- Future integrations (NOT used in Phase 1, here for documentation) -----
# GOOGLE_CALENDAR_CLIENT_ID=""
# WEATHER_API_KEY=""
